__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.venv/
venv/
*.egg-info/
.DS_Store

# data
data/raw/
data/*.duckdb
data/*.duckdb.wal
data/models/
# glob the contents (not the dir itself) so the negations below can re-include
# specific files — gitignore can't un-exclude a file under a wholesale-excluded dir.
data/reports/*
# …except the small JSON summaries publish.py reads into analytics.json — kept in
# git so the nightly deploy doesn't have to re-run the (expensive) full-season
# backtest just to populate the Analytics page. Regenerate via `fplscout train`
# and `fplscout backtest` whenever the model/data materially changes.
!data/reports/phase3_validation_latest.json
!data/reports/phase6_backtest_latest.json
*.csv
!tests/fixtures/**/*.csv
# the one CSV that must live in git: pre-deadline ep_next snapshots accumulated
# by the nightly deploy (its DuckDB is ephemeral — this file IS the archive)
!data/ep_next_archive.csv

# secrets
.env
config/rules.local.yaml

# frontend (site/ — Vite + React + Tailwind, deployed to GitHub Pages)
site/node_modules/
site/dist/
# generated by `fplscout publish`, not hand-authored — CI regenerates it before
# every deploy (see .github/workflows), so it doesn't need to live in git
site/public/data/
